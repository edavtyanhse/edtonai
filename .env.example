# Database Configuration
POSTGRES_USER=anton
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edtonai

# AI Provider Configuration (DeepSeek)
AI_PROVIDER=deepseek-chat
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# AI Model Parameters
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192
AI_TIMEOUT_SECONDS=120
AI_MAX_RETRIES=3


# Logging
LOG_LEVEL=INFO
APP_ENV=development

# Auth
JWT_SECRET_KEY=development-only-insecure-secret-change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_COOKIE_PATH=/

# Limits and baseline abuse protection
MAX_RESUME_CHARS=15000
MAX_VACANCY_CHARS=10000
AUTH_RATE_LIMIT_PER_MINUTE=20
AI_RATE_LIMIT_PER_MINUTE=120
SCRAPER_RATE_LIMIT_PER_MINUTE=30

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
