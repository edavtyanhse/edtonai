# Database Configuration
POSTGRES_USER=anton
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edtonai

# AI Provider Configuration (DeepSeek)
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
GROQ_API_KEY=gsk-your-api-key-here
AI_PROVIDER_PARSING=groq
AI_PROVIDER_REASONING=deepseek
HF_TOKEN=
HF_ENDPOINT_URL=

# AI Model Parameters
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192
AI_TIMEOUT_SECONDS=120
AI_MAX_RETRIES=3


# Logging
LOG_LEVEL=INFO
APP_ENV=development
DB_AUTO_CREATE=false

# Auth
JWT_SECRET_KEY=development-only-insecure-secret-change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_COOKIE_PATH=/

# SMTP
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Public URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://localhost:8000

# OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=

# Limits and baseline abuse protection
MAX_RESUME_CHARS=15000
MAX_VACANCY_CHARS=10000
AUTH_RATE_LIMIT_PER_MINUTE=20
AI_RATE_LIMIT_PER_MINUTE=120
SCRAPER_RATE_LIMIT_PER_MINUTE=30
CHECKOUT_RATE_LIMIT_PER_MINUTE=10
PAYMENT_WEBHOOK_RATE_LIMIT_PER_MINUTE=120
PAYMENT_WEBHOOK_MAX_BODY_BYTES=16384
TRUSTED_PROXY_IPS=
AI_MONTHLY_FREE_QUOTA=5
AI_MONTHLY_TRIAL_QUOTA=100
BILLING_TEMPORARY_HIGH_FREE_QUOTA_ENABLED=false
SCRAPER_ALLOWED_HOSTS=hh.ru,hh.kz,headhunter.ru,headhunter.kz
SCRAPER_TIMEOUT_SECONDS=15
SCRAPER_MAX_HTML_BYTES=1000000
SCRAPER_MAX_REDIRECTS=5
HH_API_USER_AGENT="EdTonAI/1.0 (contact@edtonai.tech)"

# Billing / payments
PAYMENT_PROVIDER=disabled
PAYMENT_WEBHOOK_REPLAY_TOLERANCE_SECONDS=300
TBANK_TERMINAL_KEY=
TBANK_PUBLIC_KEY=
TBANK_PASSWORD=
# Optional compatibility placeholder; T-Bank webhook token is verified with terminal password.
TBANK_WEBHOOK_SECRET=

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=
VITE_CLARITY_PROJECT_ID=

# Google Cloud deploy
DEPLOY_REGION=us-east1
AR_HOSTNAME=us-east1-docker.pkg.dev
AR_REPO=edtonai-repo
BACKEND_SERVICE_NAME=edtonai-backend
FRONTEND_SERVICE_NAME=edtonai-frontend
